htmlcov/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docs (not needed at runtime)
README.md
docs/

# Docker files themselves (no need to copy into the image)
Dockerfile
docker-compose.yml
.dockerignore
